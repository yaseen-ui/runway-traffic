              "mode": "raw",
              "raw": "{\n  \"flightNumber\": \"AI203\",\n  \"airline\": \"Air India Updated\",\n  \"type\": \"takeoff\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/flights/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["flights", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Flight ID to update"
                }
              ]
            },
            "description": "Update flight details. Only waiting flights can be updated."
          },
          "response": []
        },
        {
          "name": "Delete Flight",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/flights/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["flights", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Flight ID to delete"
                }
              ]
            },
            "description": "Delete a flight from the queue. Only waiting flights can be deleted."
          },
          "response": []
